    </main>

    <!-- MODAL DE CONTACTOS -->
    <div id="contactModal" class="fixed inset-0 bg-black/80 backdrop-blur-md hidden items-center justify-center z-50 p-4" onclick="if(event.target===this) closeContactModal()">
        <div class="glass-panel w-full max-w-sm rounded-3xl p-6 shadow-2xl">
            <h3 class="text-lg font-bold text-white mb-3 flex items-center gap-2 font-outfit"><i data-lucide="users" class="text-blue-500"></i> Contactos</h3>
            <input type="text" id="contactSearch" placeholder="Escribe para buscar..." class="mb-4">
            <div id="contactList" class="max-h-72 overflow-y-auto space-y-2 pr-1"></div>
            <button onclick="closeContactModal()" class="mt-4 w-full py-3 bg-zinc-900 hover:bg-zinc-800 text-white font-bold rounded-2xl text-xs transition-colors">Cerrar</button>
        </div>
    </div>

    <!-- CONTROL LOGIC DEL CLIENTE (JS) -->
    <script>
        const socket = io();
        let db = { training:[], learning:[], reminders:[], excluded:[], stats:{ replied:0, total:0 }, backupPhone:'', responseDelay:0, queueInterval:3000 };
        let currentMediaType = 'text';
        let selectedFiles = [];
        let contacts = [];
        let activePhoneField = null, activeNameField = null;

        // Mostrar Feedback Visual Personalizado
        function showToast(title, msg, icon = "info", type = "info") {
            const toast = document.getElementById('custom-toast');
            document.getElementById('toast-title').innerText = title;
            document.getElementById('toast-msg').innerText = msg;
            
            const iconEl = document.getElementById('toast-icon');
            iconEl.setAttribute('data-lucide', icon);
            
            const iconBg = document.getElementById('toast-icon-bg');
            if (type === "success") {
                iconBg.className = "w-10 h-10 rounded-xl bg-green-500/10 text-green-400 flex items-center justify-center";
            } else if (type === "error") {
                iconBg.className = "w-10 h-10 rounded-xl bg-red-500/10 text-red-400 flex items-center justify-center";
            } else {
                iconBg.className = "w-10 h-10 rounded-xl bg-blue-500/10 text-blue-400 flex items-center justify-center";
            }
            
            lucide.createIcons();
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3500);
        }

        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('-translate-x-full'); }
        function closeMobileSidebar() { if(window.innerWidth<1024) document.getElementById('sidebar').classList.add('-translate-x-full'); }
        
        function nav(id) { 
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active')); 
            document.getElementById('p-' + id).classList.add('active'); 
            document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active')); 
            document.getElementById('n-' + id).classList.add('active'); 
            lucide.createIcons(); 
        }

        // Reloj Sincronizado en Zona RD
        function updateClock() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('es-ES', { timeZone:'America/Santo_Domingo', hour12:true, hour:'2-digit', minute:'2-digit', second:'2-digit' });
            const dateStr = now.toLocaleDateString('es-ES', { timeZone:'America/Santo_Domingo', weekday:'long', year:'numeric', month:'long', day:'numeric' });
            document.getElementById('clock-time').innerText = timeStr;
            document.getElementById('clock-date').innerText = dateStr;
        }
        setInterval(updateClock, 1000); 
        updateClock();

        // Modal de búsqueda de Contactos
        function openContactModal(phoneField, nameField) { 
            activePhoneField = phoneField; 
            activeNameField = nameField; 
            document.getElementById('contactModal').classList.remove('hidden'); 
            renderContactList(); 
        }
        function closeContactModal() { 
            document.getElementById('contactModal').classList.add('hidden'); 
            activePhoneField = null; 
        }
        function renderContactList() { 
            const search = document.getElementById('contactSearch').value.toLowerCase(); 
            const filtered = contacts.filter(c => (c.name && c.name.toLowerCase().includes(search)) || c.number.includes(search)); 
            const list = document.getElementById('contactList'); 
            if(!filtered.length){ 
                list.innerHTML = '<div class="text-center py-4 text-zinc-500 text-xs">Sin registros de contacto</div>'; 
                return; 
            } 
            list.innerHTML = filtered.map(c => `
                <div class="p-3 bg-white/5 hover:bg-blue-600/10 rounded-xl cursor-pointer transition-colors" onclick="selectContact('${c.number}','${c.name.replace(/'/g,"\\'")}')">
                    <div class="font-bold text-white text-xs">${c.name || 'Desconocido'}</div>
                    <div class="text-[10px] text-zinc-500 mt-0.5">${c.number}</div>
                </div>
            `).join(''); 
        }
        function selectContact(number, name){ 
            if(activePhoneField) document.getElementById(activePhoneField).value = number; 
            if(activeNameField && document.getElementById(activeNameField)) document.getElementById(activeNameField).value = name; 
            closeContactModal(); 
        }
        document.getElementById('contactSearch')?.addEventListener('input', renderContactList);
        socket.on('contacts_update', data => { contacts = data; if(!document.getElementById('contactModal').classList.contains('hidden')) renderContactList(); });

        // Tipo multimedia para respuestas
        function setMediaType(type){ 
            currentMediaType = type; 
            document.querySelectorAll('.media-type-btn').forEach(b => b.classList.remove('active')); 
            document.getElementById('mt-' + type).classList.add('active'); 
            document.getElementById('media-upload').classList.toggle('hidden', type === 'text'); 
            if(type !== 'text') {
                document.getElementById('t-media').accept = type === 'image' ? 'image/*' : 'video/*';
            }
        }
        document.getElementById('t-media')?.addEventListener('change', function(e){ 
            selectedFiles = Array.from(e.target.files); 
            const preview = document.getElementById('media-preview'); 
            preview.innerHTML = ''; 
            selectedFiles.forEach(f => { 
                const reader = new FileReader(); 
                reader.onload = ev => { 
                    const img = document.createElement('img'); 
                    img.src = ev.target.result; 
                    img.className = 'media-preview'; 
                    preview.appendChild(img); 
                }; 
                reader.readAsDataURL(f); 
            }); 
        });

        // Eventos de Sockets para estado de WhatsApp
        socket.on('connection_status', data => { 
            const qrDiv = document.getElementById('qr-container'); 
            const connDiv = document.getElementById('connected-container'); 
            const logoutBtn = document.getElementById('btn-logout-wa'); 
            const statusSpan = document.getElementById('bot-status'); 
            const dot = document.getElementById('dot'); 
            
            if(data.connected){ 
                qrDiv.style.display = 'none'; 
                connDiv.style.display = 'block'; 
                logoutBtn.style.display = 'block'; 
                statusSpan.innerText = 'Conectado'; 
                dot.className = 'w-2 h-2 rounded-full bg-emerald-400'; 
                document.getElementById('wa-status-text').innerText = 'Bot en línea y activo'; 
                document.getElementById('conn-status-card').className = 'flex items-center gap-3 p-4 bg-emerald-500/5 border border-emerald-500/10 rounded-2xl';
            }else{ 
                qrDiv.style.display = 'flex'; 
                connDiv.style.display = 'none'; 
                logoutBtn.style.display = 'none'; 
                statusSpan.innerText = data.status || 'Desconectado'; 
                dot.className = 'w-2 h-2 rounded-full bg-red-500 animate-pulse'; 
                document.getElementById('wa-status-text').innerText = 'Esperando conexión QR...'; 
                document.getElementById('conn-status-card').className = 'flex items-center gap-3 p-4 bg-red-500/5 border border-red-500/10 rounded-2xl';
            } 
        });
        socket.on('qr_update', url => { document.getElementById('qr-img').innerHTML = `<img src="${url}" class="w-48 h-48 rounded-xl">`; });
        socket.on('qr_clear', () => { document.getElementById('qr-img').innerHTML = '<span class="text-zinc-500 text-xs font-bold block p-12">Generando Código QR...</span>'; });
        socket.on('data_update', data => { db = data; render(); });
        
        socket.on('config_update', cfg => { 
            if(cfg.responseDelay !== undefined){ 
                document.getElementById('response-delay').value = cfg.responseDelay; 
                document.getElementById('delay-value').innerText = cfg.responseDelay.toFixed(1) + ' s'; 
            } 
            if(cfg.queueInterval !== undefined){ 
                document.getElementById('queue-interval').value = cfg.queueInterval; 
                document.getElementById('interval-value').innerText = cfg.queueInterval + ' ms'; 
            } 
        });

        // API Fetch y Renderizado General
        async function load(){ 
            const res = await fetch('/api/data'); 
            if(res.status === 401){ 
                location.href = '/login'; 
                return; 
            } 
            const data = await res.json(); 
            db = data; 
            document.getElementById('conf-backup-phone').value = data.backupPhone || ''; 
            document.getElementById('response-delay').value = data.responseDelay || 0; 
            document.getElementById('delay-value').innerText = (data.responseDelay || 0).toFixed(1) + ' s'; 
            document.getElementById('queue-interval').value = data.queueInterval || 3000; 
            document.getElementById('interval-value').innerText = (data.queueInterval || 3000) + ' ms'; 
            render(); 
            const contactsRes = await fetch('/api/contacts'); 
            contacts = await contactsRes.json(); 
        }

        function render(){ 
            document.getElementById('s-replied').innerText = db.stats?.replied || 0; 
            document.getElementById('s-total').innerText = db.stats?.total || 0; 
            const today = new Date().toISOString().slice(0, 10); 
            const todayCount = (db.reminders || []).filter(r => r.date.startsWith(today)).length; 
            document.getElementById('today-reminders-count').innerText = todayCount; 
            
            // Listado de Respuestas entrenadas
            document.getElementById('l-train').innerHTML = (db.training || []).map(t => `
                <div class="glass-card p-5 rounded-2xl">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="px-2.5 py-1 bg-blue-500/10 text-blue-400 text-[9px] font-bold rounded-lg uppercase tracking-wider">Desencadenante</span>
                            <b class="text-white block mt-2 text-sm">"${escapeHtml(t.key)}"</b>
