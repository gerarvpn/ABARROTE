            lucide.createIcons(); 
        }

        function escapeHtml(str){ 
            if(!str) return ''; 
            return str.replace(/[&<>]/g, function(m){ 
                if(m === '&') return '&amp;'; 
                if(m === '<') return '&lt;'; 
                if(m === '>') return '&gt;'; 
                return m;
            }); 
        }

        async function saveTrain(e){ 
            e.preventDefault(); 
            const fd = new FormData(); 
            fd.append('id', document.getElementById('t-id').value); 
            fd.append('key', document.getElementById('t-key').value); 
            fd.append('response', document.getElementById('t-res').value); 
            if(currentMediaType !== 'text' && selectedFiles.length) {
                selectedFiles.forEach(f => fd.append('media', f));
            } 
            const res = await fetch('/api/train', {method:'POST', body:fd}); 
            if(res.ok){ 
                showToast('Operación Éxitoso', 'La regla se ha guardado correctamente.', 'check', 'success'); 
                document.getElementById('t-id').value = ''; 
                document.getElementById('t-key').value = ''; 
                document.getElementById('t-res').value = ''; 
                selectedFiles = []; 
                document.getElementById('t-media').value = ''; 
                document.getElementById('media-preview').innerHTML = ''; 
                setMediaType('text'); 
                load(); 
            } else {
                showToast('Fallo del Servidor', 'No se pudo guardar la regla.', 'alert-triangle', 'error');
            }
        }

        function editT(id){ 
            const t = db.training.find(t => t.id == id); 
            document.getElementById('t-id').value = t.id; 
            document.getElementById('t-key').value = t.key; 
            document.getElementById('t-res').value = t.response; 
            if(t.mediaPaths && JSON.parse(t.mediaPaths).length) {
                setMediaType('image');
            } 
            window.scrollTo({top:0, behavior:'smooth'}); 
        }

        async function delT(id){ 
            if(confirm('¿Eliminar esta regla definitivamente?')){ 
                await fetch('/api/train/' + id, {method:'DELETE'}); 
                load(); 
                showToast('Registro Removido', 'La regla fue eliminada.', 'trash', 'success'); 
            } 
        }

        function useL(id){ 
            const l = db.learning.find(l => l.id == id); 
            document.getElementById('t-key').value = l.text; 
            nav('train'); 
        }

        async function delL(id){ 
            await fetch('/api/learning/' + id, {method:'DELETE'}); 
            load(); 
        }

        async function saveRem(){ 
            const data = { 
                id: document.getElementById('r-id').value, 
                name: document.getElementById('r-name').value, 
                phone: document.getElementById('r-phone').value, 
                message: document.getElementById('r-msg').value, 
                freq: document.getElementById('r-freq').value, 
                date: document.getElementById('r-date').value 
            }; 
            if(!data.name || !data.phone || !data.message || !data.date){ 
                showToast('Datos Incompletos', 'Completa la información antes de continuar.', 'alert-triangle', 'error'); 
                return; 
            } 
            await fetch('/api/reminders', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)}); 
            showToast('Guardado', 'El recordatorio ha sido programado con éxito.', 'bell', 'success'); 
            document.getElementById('r-id').value = ''; 
            document.getElementById('r-name').value = ''; 
            document.getElementById('r-phone').value = ''; 
            document.getElementById('r-msg').value = ''; 
            document.getElementById('r-date').value = ''; 
            load(); 
        }

        function editR(id){ 
            const r = db.reminders.find(r => r.id == id); 
            document.getElementById('r-id').value = r.id; 
            document.getElementById('r-name').value = r.name; 
            document.getElementById('r-phone').value = r.phone; 
            document.getElementById('r-msg').value = r.message; 
            document.getElementById('r-freq').value = r.freq; 
            document.getElementById('r-date').value = r.date; 
            window.scrollTo({top:0, behavior:'smooth'}); 
        }

        async function delR(id){ 
            if(confirm('¿Eliminar este recordatorio?')){ 
                await fetch('/api/reminders/' + id, {method:'DELETE'}); 
                load(); 
                showToast('Eliminado', 'Se ha removido el recordatorio.', 'check', 'success');
            } 
        }

        async function saveExcl(){ 
            const name = document.getElementById('e-name').value;
            const phone = document.getElementById('e-phone').value; 
            if(!name || !phone) return; 
            await fetch('/api/exclude', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({name, phone})}); 
            showToast('Añadido', 'El número ahora se encuentra excluido.', 'shield-alert', 'success'); 
            document.getElementById('e-name').value = ''; 
            document.getElementById('e-phone').value = ''; 
            load(); 
        }

        async function delE(id){ 
            if(confirm('¿Reincorporar este contacto?')){ 
                await fetch('/api/exclude/' + id, {method:'DELETE'}); 
                load(); 
                showToast('Eliminado', 'Se removió la exclusión del contacto.', 'user', 'success');
            } 
        }

        async function saveCredentials(){ 
            const user = document.getElementById('conf-user').value;
            const pass = document.getElementById('conf-pass').value; 
            if(!user && !pass) return; 
            await fetch('/api/config/credentials', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({user, pass})}); 
            showToast('Sincronizado', 'Credenciales actualizadas. Redirigiendo...', 'key', 'success'); 
            setTimeout(() => location.href = '/login', 1500); 
        }

        async function saveBackupPhone(){ 
            const phone = document.getElementById('conf-backup-phone').value.replace(/\D/g, ''); 
            await fetch('/api/config/backup-phone', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({backupPhone: phone})}); 
            showToast('Sincronizado', 'Número de backup guardado con éxito.', 'save', 'success'); 
        }

        async function saveConfiguracionEnvio(){ 
            const delay = parseFloat(document.getElementById('response-delay').value); 
            const interval = parseInt(document.getElementById('queue-interval').value); 
            await fetch('/api/config/delay', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({delay})}); 
            await fetch('/api/config/queue-interval', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({interval})}); 
            showToast('Parámetros Guardados', 'Los cambios en la latencia ya están aplicados.', 'check', 'success'); 
        }

        function downloadBackup(){ window.location.href = '/api/backup/download'; }
        function downloadTemplate(){ window.location.href = '/api/train/template'; }

        async function sendBackupManually(){ 
            const phone = document.getElementById('conf-backup-phone').value; 
            if(!phone){ 
                showToast('Atención', 'Especifica un número para backups primero.', 'alert-triangle', 'error'); 
                return; 
            } 
            const res = await fetch('/api/backup/send', {method:'POST'}); 
            const data = await res.json(); 
            if(data.ok) showToast('Éxito', 'Backup transmitido de forma directa.', 'send', 'success'); 
            else showToast('Fallo', 'Ocurrió un error al enviar el archivo.', 'alert-triangle', 'error'); 
        }

        async function restoreBackup(input){ 
            if(!input.files[0]) return; 
            if(!confirm('¿Restablecer el bot usando este archivo?')) { input.value=''; return; } 
            const fd = new FormData(); 
            fd.append('backup', input.files[0]); 
            const res = await fetch('/api/backup/restore', {method:'POST', body:fd}); 
            if(res.ok){ 
                showToast('Restauración Completa', 'Recargando el sistema...', 'database', 'success'); 
                setTimeout(() => location.reload(), 1500); 
            } else {
                showToast('Fallo', 'Formato de archivo inválido.', 'alert-triangle', 'error'); 
            }
            input.value = ''; 
        }

        async function importTraining(input){ 
            if(!input.files[0]) return; 
            const fd = new FormData(); 
            fd.append('file', input.files[0]); 
            const res = await fetch('/api/train/import', {method:'POST', body:fd}); 
            const data = await res.json(); 
            if(data.ok){ 
                showToast('Importación Éxitosa', `Se agregaron ${data.imported} respuestas nuevas.`, 'upload-cloud', 'success'); 
                load(); 
            } else {
                showToast('Fallo', 'Error al procesar el archivo.', 'alert-triangle', 'error');
            }
            input.value = ''; 
        }

        async function logoutWA(){ 
            if(confirm('¿Desvincular WhatsApp definitivamente del servidor?')){ 
                await fetch('/api/logout-wa', {method:'POST'}); 
                showToast('Desvinculado', 'Saliendo de la sesión de WhatsApp...', 'log-out', 'success'); 
                setTimeout(() => location.reload(), 2000); 
            } 
        }

        function logout(){ location.href = '/login'; }

        document.getElementById('response-delay')?.addEventListener('input', e => document.getElementById('delay-value').innerText = parseFloat(e.target.value).toFixed(1) + ' s');
        document.getElementById('queue-interval')?.addEventListener('input', e => document.getElementById('interval-value').innerText = e.target.value + ' ms');
        
        window.onload = load;
    </script>
</body>
</html>
