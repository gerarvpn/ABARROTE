                                <div class="flex justify-between items-center text-xs">
                                    <span class="text-zinc-400 font-bold">Retardo (segundos)</span>
                                    <span id="delay-value" class="font-mono text-blue-400 font-bold">0.0 s</span>
                                </div>
                                <input type="range" id="response-delay" min="0" max="10" step="0.5" value="0" class="w-full">
                            </div>
                            
                            <div class="space-y-2">
                                <div class="flex justify-between items-center text-xs">
                                    <span class="text-zinc-400 font-bold">Intervalo de Cola (milisegundos)</span>
                                    <span id="interval-value" class="font-mono text-orange-400 font-bold">3000 ms</span>
                                </div>
                                <input type="range" id="queue-interval" min="500" max="10000" step="100" value="3000" class="w-full">
