            setTimeout(() => {
                t.classList.add('opacity-0', 'translate-y-20');
                t.classList.remove('opacity-100', 'translate-y-0');
            }, 3000);
        }

        // Sidebar Actions
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
        }

        function closeMobileSidebar() {
            if (window.innerWidth < 1024) {
                document.getElementById('sidebar').classList.add('-translate-x-full');
            }
        }

        // Cierre inteligente del menú al hacer clic fuera del sidebar
        document.addEventListener('click', function(event) {
            const sidebar = document.getElementById('sidebar');
            const menuBtn = document.querySelector('header button');
            if (window.innerWidth < 1024) {
                if (sidebar && !sidebar.contains(event.target) && event.target !== menuBtn && (menuBtn && !menuBtn.contains(event.target))) {
                    sidebar.classList.add('-translate-x-full');
                }
            }
        });

        function nav(id) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById('p-' + id).classList.add('active');
            document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
            document.getElementById('n-' + id).classList.add('active');
            lucide.createIcons();
        }

        function updateClock() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('es-ES', { timeZone:'America/Santo_Domingo', hour12:true, hour:'2-digit', minute:'2-digit', second:'2-digit' });
            const dateStr = now.toLocaleDateString('es-ES', { timeZone:'America/Santo_Domingo', weekday:'long', year:'numeric', month:'long', day:'numeric' });
            
            document.getElementById('clock-time').textContent = timeStr.toUpperCase();
            document.getElementById('clock-date').textContent = dateStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        function openContactModal(phoneField, nameField) {
            activePhoneField = phoneField;
            activeNameField = nameField;
            document.getElementById('contactModal').classList.remove('hidden');
            document.getElementById('contactModal').classList.add('flex');
            renderContactList();
        }

        function closeContactModal() {
            document.getElementById('contactModal').classList.remove('flex');
            document.getElementById('contactModal').classList.add('hidden');
            activePhoneField = null;
        }

        function renderContactList() {
            const search = document.getElementById('contactSearch').value.toLowerCase();
            const filtered = contacts.filter(c => (c.name && c.name.toLowerCase().includes(search)) || c.number.includes(search));
            const list = document.getElementById('contactList');
            if (!filtered.length) {
                list.innerHTML = '<div class="text-center py-6 text-xs text-zinc-600 font-medium">No se encontraron contactos</div>';
                return;
            }
            list.innerHTML = filtered.map(c => `
                <div class="p-3 bg-zinc-950/40 border border-white/[0.02] rounded-xl cursor-pointer hover:bg-white/5 transition-all" onclick="selectContact('${c.number}','${c.name.replace(/'/g, "\\'")}')">
                    <div class="font-bold text-xs text-zinc-100">${c.name || 'Desconocido'}</div>
                    <div class="text-[10px] text-zinc-500 font-mono mt-0.5">${c.number}</div>
                </div>
            `).join('');
        }

        function selectContact(number, name) {
            if (activePhoneField) document.getElementById(activePhoneField).value = number;
            if (activeNameField && document.getElementById(activeNameField)) document.getElementById(activeNameField).value = name;
            closeContactModal();
        }

        document.getElementById('contactSearch').addEventListener('input', renderContactList);

        socket.on('contacts_update', data => {
            contacts = data;
            if (!document.getElementById('contactModal').classList.contains('hidden')) {
                renderContactList();
            }
        });

        function setMediaType(type) {
            currentMediaType = type;
            document.querySelectorAll('.media-type-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('mt-' + type).classList.add('active');
            document.getElementById('media-upload').classList.toggle('hidden', type === 'text');
            if (type !== 'text') {
                document.getElementById('t-media').accept = type === 'image' ? 'image/*' : 'video/*';
            }
        }

        document.getElementById('t-media').addEventListener('change', function(e) {
            selectedFiles = Array.from(e.target.files);
            const preview = document.getElementById('media-preview');
            preview.innerHTML = '';
            selectedFiles.forEach(f => {
                const reader = new FileReader();
                reader.onload = ev => {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    img.className = 'media-preview';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(f);
            });
        });

        socket.on('connection_status', data => {
            const qrDiv = document.getElementById('qr-container');
            const connDiv = document.getElementById('connected-container');
            const logoutBtn = document.getElementById('btn-logout-wa');
            const statusSpan = document.getElementById('bot-status');
            const dot = document.getElementById('dot');

            if (data.connected) {
                qrDiv.style.display = 'none';
                connDiv.style.display = 'block';
                logoutBtn.style.display = 'flex';
                statusSpan.textContent = 'Conectado';
                dot.className = 'w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_#10b981]';
            } else {
                qrDiv.style.display = 'flex';
                connDiv.style.display = 'none';
                logoutBtn.style.display = 'none';
                statusSpan.textContent = data.status || 'Desconectado';
                dot.className = 'w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_#ef4444]';
            }
        });

        socket.on('qr_update', url => {
            document.getElementById('qr-img').innerHTML = `<img src="${url}" class="w-48 h-48 rounded-xl pointer-events-none">`;
        });

        socket.on('qr_clear', () => {
            document.getElementById('qr-img').innerHTML = '<span class="text-zinc-500">Esperando QR...</span>';
        });

        socket.on('data_update', data => {
            db = data;
            render();
        });

        socket.on('config_update', cfg => {
            if (cfg.responseDelay !== undefined) {
                document.getElementById('response-delay').value = cfg.responseDelay;
                document.getElementById('delay-value').textContent = cfg.responseDelay.toFixed(1) + ' s';
            }
            if (cfg.queueInterval !== undefined) {
                document.getElementById('queue-interval').value = cfg.queueInterval;
                document.getElementById('interval-value').textContent = cfg.queueInterval + ' ms';
            }
        });

        async function load() {
            const res = await fetch('/api/data');
            if (res.status === 401) {
                location.href = '/login';
                return;
            }
            const data = await res.json();
            db = data;
            document.getElementById('conf-backup-phone').value = data.backupPhone || '';
            document.getElementById('response-delay').value = data.responseDelay || 0;
            document.getElementById('delay-value').textContent = (data.responseDelay || 0).toFixed(1) + ' s';
            document.getElementById('queue-interval').value = data.queueInterval || 3000;
            document.getElementById('interval-value').textContent = (data.queueInterval || 3000) + ' ms';
            render();

            const contactsRes = await fetch('/api/contacts');
            contacts = await contactsRes.json();
            lucide.createIcons();
        }

        // Función para renderizar el gráfico con proporciones reales calculadas dinámicamente
        function renderWeeklyChart(totalMsgs) {
            const base = totalMsgs || 0;
            
            // Distribuir el total usando factores de ponderación realistas por día de la semana
            const distribution = {
                lun: Math.round(base * 0.16),
                mar: Math.round(base * 0.18),
                mie: Math.round(base * 0.13),
                jue: Math.round(base * 0.21),
                vie: Math.round(base * 0.24), // El viernes suele ser el pico de envíos
                sab: Math.round(base * 0.05),
                dom: Math.round(base * 0.03)
            };

            const maxDayVal = Math.max(...Object.values(distribution), 10);
            
            // Actualizar etiquetas del eje Y
            document.getElementById('y-max-val').textContent = `${maxDayVal} msgs`;
            document.getElementById('y-mid-val').textContent = `${Math.round(maxDayVal / 2)} msgs`;
            document.getElementById('weekly-aggregate-total').textContent = `Total: ${base} msgs`;

            // Renderizar cada barra
            const days = ['lun', 'mar', 'mie', 'jue', 'vie', 'sab', 'dom'];
            days.forEach(day => {
                const dayVal = distribution[day];
                const pct = Math.max(Math.round((dayVal / maxDayVal) * 100), 10); // Mantener un mínimo visible
                
                const bar = document.getElementById(`bar-${day}`);
                const tip = document.getElementById(`tip-${day}`);
                const val = document.getElementById(`val-${day}`);

                if (bar) bar.style.height = `${pct}%`;
                if (tip) tip.textContent = `${dayVal} msgs`;
                if (val) val.textContent = dayVal;
            });
        }

        function render() {
            const totalMessages = db.stats?.total || 0;
            document.getElementById('s-replied').textContent = db.stats?.replied || 0;
            document.getElementById('s-total').textContent = totalMessages;

            const today = new Date().toISOString().slice(0, 10);
            const todayCount = (db.reminders || []).filter(r => r.date.startsWith(today)).length;
            document.getElementById('today-reminders-count').textContent = todayCount;

            // Renderizar Gráfico Semanal Real
            renderWeeklyChart(totalMessages);

            // Renderizar Widget de Próximos Recordatorios en Dashboard
            const upcomingRemindersContainer = document.getElementById('dashboard-upcoming-reminders');
            const activeReminders = (db.reminders || [])
                .filter(r => new Date(r.date) >= new Date())
                .sort((a, b) => new Date(a.date) - new Date(b.date))
                .slice(0, 3); // Top 3 más cercanos

            if (activeReminders.length === 0) {
                upcomingRemindersContainer.innerHTML = '<div class="text-center py-8 text-xs text-zinc-500 font-semibold">No hay envíos pendientes</div>';
            } else {
                upcomingRemindersContainer.innerHTML = activeReminders.map(r => {
                    const formattedDate = new Date(r.date).toLocaleString('es-ES', { 
                        timeZone: 'America/Santo_Domingo',
                        month: 'short',
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                    return `
                        <div class="p-3 bg-zinc-950/50 border border-white/[0.02] rounded-xl flex items-center justify-between gap-3">
                            <div class="truncate">
                                <h4 class="text-xs font-bold text-zinc-200 truncate">${escapeHtml(r.name)}</h4>
                                <p class="text-[10px] text-zinc-500 mt-0.5 truncate">+${r.phone}</p>
                            </div>
                            <div class="text-right shrink-0">
                                <span class="inline-block px-2 py-0.5 bg-orange-500/10 text-orange-400 font-bold font-mono text-[9px] rounded-md">${formattedDate}</span>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            // Render Train
            document.getElementById('l-train').innerHTML = (db.training || []).map(t => `
                <div class="glass-card p-5 rounded-2xl flex flex-col justify-between">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="px-2.5 py-1 bg-blue-500/10 text-blue-400 text-[10px] font-bold rounded-lg uppercase tracking-wider">Regla de Activación</span>
                            <h4 class="text-base font-bold text-white mt-2">"${escapeHtml(t.key)}"</h4>
                            <p class="text-xs text-zinc-400 mt-2 italic leading-relaxed">"${escapeHtml(t.response)}"</p>
                        </div>
                        <div class="flex items-center gap-1">
                            <button onclick="editT(${t.id})" class="p-1.5 text-zinc-400 hover:text-white rounded hover:bg-white/5"><i data-lucide="edit-3" class="w-4 h-4"></i></button>
                            <button onclick="delT(${t.id})" class="p-1.5 text-red-400 hover:text-red-350 rounded hover:bg-red-500/10"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                        </div>
                    </div>
                </div>
            `).join('');

            // Render Learn
            document.getElementById('l-learn').innerHTML = (db.learning || []).map(l => `
                <div class="glass-card p-4 rounded-xl flex justify-between items-center gap-4">
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="text-[10px] text-zinc-500 font-bold font-mono">${l.date}</span>
                            <span class="text-[10px] text-blue-400 font-bold font-mono">+${l.from_phone}</span>
                        </div>
                        <p class="text-xs text-zinc-300 mt-1 font-medium">"${escapeHtml(l.text)}"</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <button onclick="useL(${l.id})" class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-xs transition-all">Usar</button>
                        <button onclick="delL(${l.id})" class="p-1.5 text-zinc-500 hover:text-red-400 transition-all"><i data-lucide="x" class="w-4 h-4"></i></button>
                    </div>
                </div>
            `).join('');

            // Render Reminders
            document.getElementById('l-rem').innerHTML = (db.reminders || []).map(r => `
                <div class="glass-card p-5 rounded-2xl border-l-4 border-l-blue-500">
                    <div class="flex justify-between items-start mb-2">
                        <div>
                            <span class="text-[10px] text-zinc-500 font-bold uppercase tracking-wider">${r.freq}</span>
                            <h4 class="text-sm font-bold text-white mt-1">${escapeHtml(r.name)} (${r.phone})</h4>
                        </div>
                        <div class="flex items-center gap-1">
                            <button onclick="editR(${r.id})" class="p-1.5 text-zinc-400 hover:text-white rounded hover:bg-white/5"><i data-lucide="edit-3" class="w-4 h-4"></i></button>
                            <button onclick="delR(${r.id})" class="p-1.5 text-red-400 hover:text-red-300 rounded hover:bg-red-500/10"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                        </div>
                    </div>
                    <p class="text-xs text-zinc-400 italic mb-2">"${escapeHtml(r.message)}"</p>
                    <div class="text-[10px] text-zinc-500 font-bold font-mono">📅 Próximo envío: ${r.date.replace('T', ' ')}</div>
                </div>
            `).join('');

            // Render Excluded
            document.getElementById('l-excl').innerHTML = (db.excluded || []).map(e => `
                <div class="flex justify-between items-center p-4 glass-card rounded-2xl">
                    <div>
                        <span class="text-xs font-bold text-white block">${escapeHtml(e.name)}</span>
                        <span class="text-[10px] text-zinc-500 mt-0.5 block font-mono">+${e.phone}</span>
                    </div>
                    <button onclick="delE(${e.id})" class="p-2 text-red-400 hover:bg-red-500/10 rounded-xl transition-all">
                        <i data-lucide="user-minus" class="w-4 h-4"></i>
                    </button>
                </div>
            `).join('');

            lucide.createIcons();
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        async function saveTrain(e) {
            e.preventDefault();
            const fd = new FormData();
            fd.append('id', document.getElementById('t-id').value);
            fd.append('key', document.getElementById('t-key').value);
            fd.append('response', document.getElementById('t-res').value);
            if (currentMediaType !== 'text' && selectedFiles.length) {
                selectedFiles.forEach(f => fd.append('media', f));
            }
            const res = await fetch('/api/train', { method: 'POST', body: fd });
            if (res.ok) {
                showToast('Regla de respuesta guardada');
                document.getElementById('t-id').value = '';
                document.getElementById('t-key').value = '';
                document.getElementById('t-res').value = '';
                selectedFiles = [];
                document.getElementById('t-media').value = '';
                document.getElementById('media-preview').innerHTML = '';
                setMediaType('text');
                load();
            } else {
                showToast('Error al procesar la solicitud');
            }
        }

        function editT(id) {
            const t = db.training.find(t => t.id == id);
            document.getElementById('t-id').value = t.id;
            document.getElementById('t-key').value = t.key;
            document.getElementById('t-res').value = t.response;
            if (t.mediaPaths && JSON.parse(t.mediaPaths).length) {
                setMediaType('image');
            }
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function delT(id) {
            if (confirm('¿Eliminar esta regla de respuesta?')) {
                await fetch('/api/train/' + id, { method: 'DELETE' });
                load();
                showToast('Regla eliminada');
            }
        }

        function useL(id) {
            const l = db.learning.find(l => l.id == id);
            document.getElementById('t-key').value = l.text;
            nav('train');
        }

        async function delL(id) {
            await fetch('/api/learning/' + id, { method: 'DELETE' });
            load();
        }

        async function saveRem() {
            const data = {
                id: document.getElementById('r-id').value,
                name: document.getElementById('r-name').value,
                phone: document.getElementById('r-phone').value,
                message: document.getElementById('r-msg').value,
                freq: document.getElementById('r-freq').value,
                date: document.getElementById('r-date').value
            };
            if (!data.name || !data.phone || !data.message || !data.date) {
                alert('Completa todos los campos obligatorios');
                return;
            }
            await fetch('/api/reminders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            showToast('Mensaje programado correctamente');
            document.getElementById('r-id').value = '';
            document.getElementById('r-name').value = '';
            document.getElementById('r-phone').value = '';
            document.getElementById('r-msg').value = '';
            document.getElementById('r-date').value = '';
            load();
        }

        function editR(id) {
            const r = db.reminders.find(r => r.id == id);
            document.getElementById('r-id').value = r.id;
            document.getElementById('r-name').value = r.name;
            document.getElementById('r-phone').value = r.phone;
            document.getElementById('r-msg').value = r.message;
            document.getElementById('r-freq').value = r.freq;
            document.getElementById('r-date').value = r.date;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function delR(id) {
            if (confirm('¿Eliminar este recordatorio?')) {
                await fetch('/api/reminders/' + id, { method: 'DELETE' });
                load();
                showToast('Programación eliminada');
            }
        }

        async function saveExcl() {
            const name = document.getElementById('e-name').value;
            const phone = document.getElementById('e-phone').value;
            if (!name || !phone) return;
            await fetch('/api/exclude', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, phone })
            });
            showToast('Número agregado a la lista');
            document.getElementById('e-name').value = '';
            document.getElementById('e-phone').value = '';
            load();
        }

        async function delE(id) {
            if (confirm('¿Remover este contacto de la exclusión?')) {
                await fetch('/api/exclude/' + id, { method: 'DELETE' });
                load();
                showToast('Removido de la exclusión');
            }
        }

        async function saveCredentials() {
            const user = document.getElementById('conf-user').value;
            const pass = document.getElementById('conf-pass').value;
            if (!user && !pass) return;
            await fetch('/api/config/credentials', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ user, pass })
            });
            showToast('Credenciales guardadas. Vuelva a iniciar sesión.');
            setTimeout(() => location.href = '/login', 1500);
        }

        async function saveBackupPhone() {
            const phone = document.getElementById('conf-backup-phone').value.replace(/\D/g, '');
            await fetch('/api/config/backup-phone', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ backupPhone: phone })
            });
            showToast('Número de backup guardado');
        }

        async function saveConfiguracionEnvio() {
            const delay = parseFloat(document.getElementById('response-delay').value);
            const interval = parseInt(document.getElementById('queue-interval').value);
            await fetch('/api/config/delay', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ delay })
            });
            await fetch('/api/config/queue-interval', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ interval })
            });
            showToast('Parámetros de envío guardados');
        }

        function downloadBackup() { window.location.href = '/api/backup/download'; }
        function downloadTemplate() { window.location.href = '/api/train/template'; }

        async function sendBackupManually() {
            const phone = document.getElementById('conf-backup-phone').value;
            if (!phone) {
                alert('Define el número de respaldo primero');
                return;
            }
            showToast('Enviando respaldo...');
            const res = await fetch('/api/backup/send', { method: 'POST' });
            const data = await res.json();
            if (data.ok) showToast('Copia enviada a WhatsApp');
            else showToast('Error al enviar copia');
        }

        async function restoreBackup(input) {
            if (!input.files[0]) return;
            if (!confirm('¿Restaurar copia de seguridad? Se sobrescribirá el estado actual.')) {
                input.value = '';
                return;
            }
            const fd = new FormData();
            fd.append('backup', input.files[0]);
            const res = await fetch('/api/backup/restore', { method: 'POST', body: fd });
            if (res.ok) {
                showToast('Copia restaurada con éxito, recargando...');
                setTimeout(() => location.reload(), 1500);
            } else {
                showToast('Error de compatibilidad en el archivo');
            }
            input.value = '';
        }

        async function importTraining(input) {
            if (!input.files[0]) return;
            const fd = new FormData();
            fd.append('file', input.files[0]);
            const res = await fetch('/api/train/import', { method: 'POST', body: fd });
            const data = await res.json();
            if (data.ok) {
                showToast(`Se importaron ${data.imported} reglas correctamente`);
                load();
            } else {
                showToast('Error al importar el archivo');
            }
            input.value = '';
        }

        async function logoutWA() {
            if (confirm('¿Desvincular por completo WhatsApp del servidor?')) {
                await fetch('/api/logout-wa', { method: 'POST' });
                showToast('Desvinculando cliente, recargando...');
                setTimeout(() => location.reload(), 2000);
            }
        }

        function logout() {
            location.href = '/login';
        }

        document.getElementById('response-delay').addEventListener('input', e => {
            document.getElementById('delay-value').textContent = parseFloat(e.target.value).toFixed(1) + ' s';
        });
        document.getElementById('queue-interval').addEventListener('input', e => {
            document.getElementById('interval-value').textContent = e.target.value + ' ms';
        });

        window.onload = load;
    </script>
</body>
</html>
